{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=novacrm.db"
  },
  "JwtSettings": {
    "Secret": "f8dd94d461715d1b9789e8e6a85885a324be42b9e3266662e9653f8307d2e01a",
    "Issuer": "NovaCRM.API",
    "Audience": "NovaCRM.Client",
    "ExpiryDays": 7
  },
  "CorsSettings": {
    "AllowedOrigins": []
  },
  "FileStorageSettings": {
    "RootPath": "uploads"
  },
  "EmailSettings": {
    "Enabled": false,
    "Host": "smtp.gmail.com",
    "Port": 587,
    "Username": "",
    "Password": "",
    "FromAddress": "noreply@novacrm.com",
    "FromName": "NovaCRM",
    "EnableSsl": true
  },
  "RateLimitSettings": {
    "AuthWindowSeconds": 60,
    "AuthPermitLimit": 10,
    "ApiWindowSeconds": 60,
    "ApiPermitLimit": 60
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{CorrelationId}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/novacrm-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "outputTemplate": "[{Timestamp:yyyy-MM-dd HH:mm:ss.fff} {Level:u3}] [{CorrelationId}] {SourceContext} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext", "WithMachineName", "WithThreadId" ]
  }
}
